---
import Base from '../layouts/Base.astro'
import ResetPasswordForm from '../components/ui/ResetPasswordForm'

const token = Astro.url.searchParams.get('token')
---

<Base title="Reset Password">
  <div class="flex min-h-screen items-center justify-center bg-[#F1F5FB] px-4 dark:bg-gray-950">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold">
          <svg class="h-8 w-8 text-primary-600 dark:text-primary-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          VibeCoder
        </a>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Set your new password</p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-card dark:border-gray-800 dark:bg-gray-900">
        <ResetPasswordForm client:load token={token} />
      </div>
    </div>
  </div>
</Base>
