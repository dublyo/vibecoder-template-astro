---
import Dashboard from '../layouts/Dashboard.astro'
import { getUserFromSession, SESSION_COOKIE } from '../lib/auth'

const token = Astro.cookies.get(SESSION_COOKIE)?.value
const user = await getUserFromSession(token)

// Redirect to login if not authenticated
if (!user) {
  return Astro.redirect('/login')
}
---

<Dashboard title="Dashboard">
  <div class="mx-auto max-w-4xl">
    <h1 class="text-2xl font-bold">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
      Welcome back, {user.name || user.email}
    </p>

    <!-- User Info Cards -->
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <p class="text-sm text-gray-500 dark:text-gray-400">Name</p>
        <p class="mt-1 font-medium">{user.name || 'Not set'}</p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <p class="text-sm text-gray-500 dark:text-gray-400">Email</p>
        <p class="mt-1 font-medium">{user.email}</p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <p class="text-sm text-gray-500 dark:text-gray-400">Role</p>
        <p class="mt-1 font-medium capitalize">{user.role}</p>
      </div>
    </div>

    <!-- Quick Start Guide -->
    <div class="mt-8 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <h2 class="text-lg font-semibold">Quick Start</h2>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
        This is your dashboard. Start building by editing the source code.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-gray-600 dark:text-gray-400">
        <li class="flex items-start gap-2">
          <span class="mt-0.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-500"></span>
          Edit pages in <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs dark:bg-gray-800">src/pages/</code>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-500"></span>
          Add API routes in <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs dark:bg-gray-800">src/pages/api/</code>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-500"></span>
          Modify the database schema in <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs dark:bg-gray-800">prisma/schema.prisma</code>
        </li>
      </ul>
    </div>
  </div>
</Dashboard>
